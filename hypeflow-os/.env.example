# =============================================================
# HYPE Flow OS — Environment Variables
# Copy to .env.local for each app
# =============================================================

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Meta (Facebook + Instagram Ads) ─────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback

# ─── Google (Ads + Calendar + Meet) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_WEBHOOK_SECRET=

# ─── LinkedIn ─────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/integrations/linkedin/callback

# ─── WhatsApp Business ────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ─── ManyChat ─────────────────────────────────────────────────
MANYCHAT_API_KEY=

# ─── N8N ──────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_API_KEY=

# ─── Make (Integromat) ────────────────────────────────────────
MAKE_WEBHOOK_URL=

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@hypeflow.pt

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_PORTAL_URL=http://localhost:3012
API_SECRET_KEY=your-internal-api-secret

# Enables mock fallback in /api/ai/* routes when ANTHROPIC_API_KEY is unset.
# Only takes effect when NODE_ENV=development. Must be 'false' (or absent) in production.
# Story 01.9 / audit C6.
NEXT_PUBLIC_DEMO_MODE=false

# Skips middleware auth checks (preview/CI builds with placeholder Supabase).
# ONLY use locally or in CI builds where auth cannot be exercised.
# NEVER set in production — turning this on disables the entire auth layer.
# Story 01.11 / audit C1.
NEXT_PUBLIC_PREVIEW_MODE=false

# ─── AI (Anthropic) ───────────────────────────────────────────
# Server-side key used by /api/ai/agent, /api/ai/copy, /api/ai/automation.
# In production, routes 500 if this is missing. In dev with NEXT_PUBLIC_DEMO_MODE=true, falls back to mock responses.
ANTHROPIC_API_KEY=

# ─── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
