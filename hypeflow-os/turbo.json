{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_DEMO_MODE",
        "NEXT_PUBLIC_PREVIEW_MODE",
        "HYPEFLOW_LOG_SALT",
        "ANTHROPIC_API_KEY",
        "EVOLUTION_TOKEN_*",
        "TALLY_SIGNING_SECRET_*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "cache": false,
      "outputs": []
    },
    "test:coverage": {
      "cache": false,
      "outputs": ["coverage/**"]
    }
  }
}
