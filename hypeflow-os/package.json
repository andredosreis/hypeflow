{
  "name": "hypeflow-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:software": "turbo run dev --filter=@hypeflow/agency --filter=@hypeflow/portal",
    "dev:agency": "npm run dev --workspace @hypeflow/agency",
    "dev:portal": "npm run dev --workspace @hypeflow/portal",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "cd supabase && supabase db push",
    "db:types": "supabase gen types typescript --local > packages/database/src/types.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.9.4",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.9.2"
}
